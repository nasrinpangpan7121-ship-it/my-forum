generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  email       String    @unique
  password    String
  displayName String?   // ชื่อที่แสดงในเว็บ รองรับทุกภาษา/อิโมจิ (ไม่บังคับ)
  profileImage String?  // URL รูปโปรไฟล์ (ไม่บังคับ)
  createdAt   DateTime  @default(now())
  posts         Post[]
  comments      Comment[]
  notifications Notification[] // การแจ้งเตือนที่ได้รับ
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  posts PostTag[]
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String
  content    String
  createdAt  DateTime  @default(now())
  author     User      @relation(fields: [authorId], references: [id])
  authorId   Int
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?
  comments   Comment[]
  tags       PostTag[]
}

model PostTag {
  post   Post @relation(fields: [postId], references: [id])
  postId Int
  tag    Tag  @relation(fields: [tagId], references: [id])
  tagId  Int
  @@id([postId, tagId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
  post      Post     @relation(fields: [postId], references: [id])
  postId    Int
}
model Notification {
  id        Int      @id @default(autoincrement())
  message   String   // ข้อความแจ้งเตือน
  isRead    Boolean  @default(false) // อ่านแล้วหรือยัง
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id]) // คนที่ได้รับแจ้งเตือน
  userId    Int
  postId    Int?     // กระทู้ที่เกี่ยวข้อง (ถ้ามี)
}